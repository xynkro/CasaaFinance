#!/usr/bin/env bash
# casaa — single-entry launcher for FinancePWA operations
# Type `casaa` (no args) to list every command.
#
# Install (one-time):
#   echo 'export PATH="$HOME/Documents/Trading/FinancePWA/bin:$PATH"' >> ~/.zshrc && source ~/.zshrc
#
# Then from anywhere on this Mac:
#   casaa               # list all commands
#   casaa ibkr          # grab IBKR positions (needs TWS open + logged in)
#   casaa grab          # cloud yahoo-grab — both accounts
#   casaa grab-sarah    # cloud yahoo-grab — sarah only
#   casaa grab-caspar   # cloud yahoo-grab — caspar only
#   casaa options       # cloud options refresh (every-30-min cron, but force now)
#   casaa brief         # daily brief brain (Mon-Fri 07:03 cron)
#   casaa wsr-lite      # wsr-lite brain (Wed/Fri 19:33 cron)
#   casaa wsr-full      # wsr-full brain (Sun 19:37 cron)
#   casaa scan          # daily options scan (10:30 SGT cron)
#   casaa deploy        # check latest deploy status
#   casaa sheets        # show latest counts per sheet
#   casaa logs          # tail Mac LaunchAgent logs (.state/)
#   casaa status        # quick health check — last hour of cron runs

set -euo pipefail

REPO="${HOME}/Documents/Trading/FinancePWA"
GH_REPO="xynkro/CasaaFinance"

cd "$REPO"

case "${1:-help}" in

  ibkr)
    # --merge: if TWS has only ONE account live (caspar OR sarah), the
    # disconnected account would grab as net_liq=0 + empty positions;
    # --merge backfills it from today's already-saved JSON so the sheet
    # doesn't get clobbered. Combined with sync.py's $0-snapshot guard,
    # this keeps both accounts visible in the PWA even on single-login
    # TWS sessions.
    echo "→ ibkr-grab — needs TWS running on localhost:7497 + logged in"
    echo "  press Ctrl+C now if TWS isn't open."
    sleep 1
    source .venv/bin/activate
    python src/ibkr_grab.py --merge --sync
    ;;

  grab)
    echo "→ yahoo-grab (cloud, both accounts)"
    gh workflow run yahoo-grab.yml --repo "$GH_REPO"
    ;;

  grab-sarah)
    echo "→ yahoo-grab (cloud, sarah only)"
    gh workflow run yahoo-grab.yml --repo "$GH_REPO" -f sarah_only=true
    ;;

  grab-caspar)
    echo "→ yahoo-grab (cloud, caspar only)"
    gh workflow run yahoo-grab.yml --repo "$GH_REPO" -f caspar_only=true
    ;;

  options)
    echo "→ options-refresh (cloud)"
    gh workflow run options-refresh.yml --repo "$GH_REPO"
    ;;

  brief|daily|daily-brief)
    echo "→ daily-brief brain"
    gh workflow run daily-brief.yml --repo "$GH_REPO"
    ;;

  wsr-lite|lite)
    echo "→ wsr-lite brain"
    gh workflow run wsr-lite.yml --repo "$GH_REPO"
    ;;

  wsr-full|full|wsr)
    echo "→ wsr-full brain"
    gh workflow run wsr-full.yml --repo "$GH_REPO"
    ;;

  scan)
    echo "→ daily options scan"
    gh workflow run daily-options-scan.yml --repo "$GH_REPO"
    ;;

  market-scan)
    echo "→ market scan"
    gh workflow run market-scan.yml --repo "$GH_REPO"
    ;;

  finnhub|calendars)
    # Finnhub daily pull — earnings + economic calendars. Filtered to our
    # portfolio + watchlist universe and US/EU/CN/JP+SG countries
    # respectively. Brain reads these for "today's catalysts" sections.
    echo "→ finnhub-calendars (cloud cron, manual trigger)"
    gh workflow run finnhub-calendars.yml --repo "$GH_REPO"
    ;;

  news|insider|finnhub-news)
    # Finnhub 4×/day pull — company news (with heuristic sentiment) +
    # insider transactions per portfolio + watchlist ticker. Brain reads
    # these for "per-position news alerts" + "unusual insider activity".
    echo "→ finnhub-news-insider (cloud cron 4×/day, manual trigger)"
    gh workflow run finnhub-news-insider.yml --repo "$GH_REPO"
    ;;

  analyst|consensus)
    # Finnhub weekly pull — Wall St analyst recommendation distribution
    # per ticker. Brain reads for "consensus shifts" + Decision card
    # thesis anchor.
    echo "→ finnhub-analyst (cloud cron Sunday, manual trigger)"
    gh workflow run finnhub-analyst.yml --repo "$GH_REPO"
    ;;

  api-usage|cost|spend)
    # Scrape Anthropic API costs from recent brain workflow runs by
    # parsing claude-code-action's result JSON in the gh logs.
    # Populates the api_usage sheet that the Settings tab reads for
    # MTD spend + per-workflow breakdown.
    # NOTE: also runs daily 23:30 UTC via api-usage.yml cron — this
    # local command exists for ad-hoc backfills.
    echo "→ api_usage_scrape (local; queries gh + writes sheet)"
    source .venv/bin/activate
    LIMIT="${2:-50}"
    python scripts/api_usage_scrape.py --limit "$LIMIT"
    ;;

  triggers|alerts)
    # Per-decision trigger evaluator. Reads decision_queue WATCHING rows,
    # joins with live_prices + exposure_posture + tv_signals, fires
    # Telegram on transitions into act_now. Cloud cron runs every 10 min
    # during US market hours; this command is for manual force/dry runs.
    echo "→ trigger_alerts (cloud cron, manual trigger)"
    if [ "${2:-}" = "dry" ]; then
      gh workflow run trigger-alerts.yml --repo "$GH_REPO" -f dry=true
    elif [ "${2:-}" = "force" ]; then
      gh workflow run trigger-alerts.yml --repo "$GH_REPO" -f force_resend=true
    else
      gh workflow run trigger-alerts.yml --repo "$GH_REPO"
    fi
    ;;

  watchlist|wl)
    # Show or edit the curated universe (`prompts/watchlist.yaml`).
    # The brain reads this to know which categories to sweep when
    # proposing fresh ideas, and tv_signals_run / screen_candidates_run
    # use it as their input universe. Output also surfaces each ticker's
    # asset_class (Risk Parity LITE bucketing).
    if [ "${2:-show}" = "edit" ]; then
      ${EDITOR:-nano} "$REPO/prompts/watchlist.yaml"
    else
      source .venv/bin/activate
      python3 -c "
from src.watchlist import get_universe, get_asset_class
from src.sync import load_env
from src import sheets as sh
load_env()
client = sh.authenticate()
u = get_universe(client)
total_unique = len(set(t for ts in u.values() for t in ts))
for cat, tickers in u.items():
    head = ', '.join(f'{t}({get_asset_class(t)})' for t in tickers[:5])
    tail = ' ...' if len(tickers) > 5 else ''
    print(f'  {cat:30} {len(tickers):3} tickers: {head}{tail}')
print(f'  {\"TOTAL UNIQUE\":30} {total_unique}')
"
    fi
    ;;

  regime)
    echo "→ regime-signals (cloud cron, manual trigger)"
    gh workflow run regime-signals.yml --repo "$GH_REPO"
    ;;

  screen)
    echo "→ screen-candidates (cloud cron, manual trigger)"
    gh workflow run screen-candidates.yml --repo "$GH_REPO"
    ;;

  yield)
    echo "→ options-yield-screener (cloud cron, manual trigger)"
    gh workflow run options-yield.yml --repo "$GH_REPO"
    ;;

  risk-parity|rp)
    echo "→ risk-parity-audit (cloud cron, manual trigger)"
    gh workflow run risk-parity-audit.yml --repo "$GH_REPO"
    ;;

  rp-recs|risk-parity-recs)
    echo "→ risk_parity_recommend (local) — generate buy recommendations from audit"
    source .venv/bin/activate
    python scripts/risk_parity_recommend.py
    ;;

  tv)
    echo "→ tv-signals (cloud cron, manual trigger — daily TV 26-indicator pull)"
    gh workflow run tv-signals.yml --repo "$GH_REPO"
    ;;

  exposure)
    # Always runs locally — needs no FMP key (works off whatever's in the
    # `regime_signals` sheet plus current snapshot rows).
    echo "→ exposure_posture (local)"
    source .venv/bin/activate
    python scripts/exposure_posture_run.py
    ;;

  breadth)
    # Local breadth-analyzer + append to regime_signals sheet. Runs the
    # market_breadth source only (no FMP gating). Useful as a quick smoke
    # test that the regime pipeline works.
    echo "→ market-breadth-analyzer (local, regime_signals row only)"
    source .venv/bin/activate
    python scripts/regime_signals_run.py
    ;;

  deploy)
    gh run list --workflow=deploy.yml --limit 5 --repo "$GH_REPO"
    ;;

  status)
    echo "=== last 10 cron runs ==="
    gh run list --limit 10 --repo "$GH_REPO" --json status,conclusion,workflowName,createdAt \
      --template '{{range .}}{{.createdAt | timeago}} {{printf "%-12s" .conclusion}} {{.workflowName}}{{"\n"}}{{end}}'
    ;;

  sheets)
    source .venv/bin/activate
    python3 -c "
from src.sync import load_env
from src import sheets as sh
load_env()
client = sh.authenticate()
ss = sh._open_sheet(client)
for tab in ['snapshot_caspar','snapshot_sarah','positions_caspar','positions_sarah','options','decision_queue','wsr_summary','daily_brief_latest','scan_results']:
    rows = ss.worksheet(tab).get_all_values()
    if len(rows) <= 1:
        print(f'  {tab:25} empty')
        continue
    last_dates = sorted(set(r[0][:10] for r in rows[1:] if r and r[0]))[-1:]
    last = last_dates[0] if last_dates else 'none'
    today_n = sum(1 for r in rows[1:] if r and r[0].startswith(last))
    print(f'  {tab:25} latest={last} ({today_n} rows on that date) | total={len(rows)-1}')
"
    ;;

  logs)
    echo "=== ibkr-grab last 30 lines ==="
    tail -n 30 "$REPO/.state/ibkr-grab-stderr.log" 2>/dev/null || echo "(no log)"
    echo "=== daily-tracker last 30 lines ==="
    tail -n 30 "$REPO/.state/daily-tracker-stderr.log" 2>/dev/null || echo "(no log)"
    ;;

  help|--help|-h|"")
    cat <<EOF
casaa — FinancePWA launcher

DATA REFRESH
  ibkr            grab IBKR positions from local TWS (TWS must be open + logged in)
  grab            cloud yahoo-grab — both accounts
  grab-sarah      cloud yahoo-grab — sarah only
  grab-caspar     cloud yahoo-grab — caspar only
  options         cloud options refresh (price + moneyness + Greeks)
  scan            daily options scan
  market-scan     market scan (broad universe)

REGIME / EXPOSURE / SCREEN
  watchlist [show|edit]  show or edit the curated ~80-ticker universe
  breadth         local market-breadth-analyzer -> regime_signals row
  regime          cloud regime-signals (breadth + ftd + dist-day + macro)
  exposure        local exposure_posture (caspar + sarah headroom)
  screen          cloud screen-candidates (vcp + canslim, FMP key required)
  yield           cloud options-yield-screener (CSP + CC candidates by yield)
  tv              cloud tv-signals (TradingView 26-indicator consensus, 1d + 1W)
  risk-parity     cloud risk-parity-audit (asset-class diversification check)
  rp-recs         local risk_parity_recommend (rebalance buy candidates → decision_queue)
  triggers [dry|force]  cloud trigger-alerts (every 10 min mkt hours; Telegram on act_now)

BRAIN
  brief           daily brief (cloud, Opus)
  wsr-lite        mid-week pulse (cloud, Opus)
  wsr-full        Monday WSR (cloud, Opus)

INSPECT
  status          last 10 cron runs (success/fail)
  sheets          latest row counts in each Google Sheet
  deploy          last 5 PWA deploys
  logs            tail Mac LaunchAgent logs

EVERYTHING USES gh CLI — NO PAT NEEDED.
EOF
    ;;

  *)
    echo "unknown command: $1"
    echo "run 'casaa' (no args) for the full list"
    exit 1
    ;;
esac
