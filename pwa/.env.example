# Casaa Finance PWA — environment configuration
# Copy to `.env` (or `.env.local`) and fill in. Never commit real values.

# ── Data source ─────────────────────────────────────────────────────────────
# Which transport the PWA reads its data tabs from:
#   gviz      = public Google Sheet CSV (default; works with no Firebase config)
#   firestore = private Firestore mirror behind Google sign-in
# Leave unset (or set to gviz) until the Firebase cutover is ready.
VITE_DATA_SOURCE=gviz

# ── Firebase web config (only needed when VITE_DATA_SOURCE=firestore) ─────────
# These come from the Firebase console: Project settings → Your apps → Web app
# → SDK setup and configuration → Config. They are PUBLIC-SAFE by design —
# access is enforced by Firebase Auth + Firestore security rules (email
# allowlist), not by keeping these secret — but we still read them from env so
# no real project values land in the repo.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
